# Core platform
PROJECT_NAME=grounded-miniapp-platform
PREVIEW_BASE_URL=http://localhost:8000
PLATFORM_DATA_DIR=/Users/rafailvv/PycharmProjects/grounded-miniapp-platform/data
PLATFORM_HOST_DATA_DIR=/Users/rafailvv/PycharmProjects/grounded-miniapp-platform/data
PREVIEW_RUNTIME_MODE=auto
PREVIEW_PORT_BASE=16000
PREVIEW_START_TIMEOUT_SEC=120

# Network and containers
PLATFORM_BACKEND_IMAGE=python:3.12-slim
PLATFORM_FRONTEND_IMAGE=node:20-alpine
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

PLATFORM_BACKEND_PORT=8000
PLATFORM_FRONTEND_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379

# Platform storage
POSTGRES_DB=grounded_platform
POSTGRES_USER=grounded
POSTGRES_PASSWORD=grounded

# LLM gateway
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Grounded Mini-App Platform
OPENROUTER_SITE_URL=http://localhost:5173

# Platform UI
VITE_PLATFORM_NAME=Grounded Mini-App Platform

# Base mini-app template defaults
BASE_MINIAPP_BACKEND_URL=http://localhost:8000
BASE_MINIAPP_FRONTEND_URL=http://localhost:5173
BASE_MINIAPP_DEFAULT_ROLE=client
BASE_MINIAPP_AUTH_ENDPOINT=http://localhost:8000/api/auth/telegram
BASE_MINIAPP_API_BASE_URL=http://localhost:8000
